<Problem>

  <!-- single domain -->
  <Domain>
    <Geometry>
              <StructuredMesh NX = "4" NY = "4" NZ = "8" LX = "0,1" LY = "0,1" LZ = "0,1" />
    </Geometry>
    <Gauss nGP="2"/>
    <Materials          fileName="materials.xml"/>
    <BoundaryConditions fileName="boundaries.xml"/>
    <Solver>
      <SinglePhaseFlowFVTPFA targetRegions="1"/>
    </Solver>
  </Domain>

  <!-- global settings (not domain specific) -->
  <SimulationParameters fileName="simparams.xml"/>

  <Output
      outputFile  = "Output/resultsXML"
      matFileName = "Output/resultsXML"
      printTimes  = "0,10,20,50,100"/>


</Problem>