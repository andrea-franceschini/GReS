<Problem>

  <!-- single domain -->
  <Domain>
    <Geometry>
              <StructuredMesh NX = "10" NY = "10" NZ = "10" LX = "0,1" LY = "0,1" LZ = "0,1" />
    </Geometry>
    <Gauss nGP="2"/>
    <Materials          fileName="materials.xml"/>
    <BoundaryConditions fileName="boundaries.xml"/>
    <Solver>
      <SinglePhaseFlowFVTPFA targetRegions="1"/>
    </Solver>
  </Domain>

  <!-- global settings (not domain specific) -->
  <SimulationParameters fileName="simparams.xml"/>

  <Output
      outputFile  = "Output/results"
      matFileName = "Output/results"
      printTimes  = "1,5,10"/>


</Problem>