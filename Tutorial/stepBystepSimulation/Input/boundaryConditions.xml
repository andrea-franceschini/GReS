<BoundaryConditions>

  <BC
      name = "fix_bottom"
      type = "Dirichlet"
      field = "surface"
      variable = "displacements"
      entityListType = "tags"
      entityList = "1"
      components = "z"
      >

    <BCevent
             time = "0"
             value = "0"
             />
  </BC>

  <BC
      name = "y_fix"
