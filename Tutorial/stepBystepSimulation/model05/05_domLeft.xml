<?xml version="1.0" encoding="UTF-8"?>
<!-- Preprocess input for non-conforming multi-domain simulation -->

<Problem>

    <Geometry>
      <StructuredMesh NX="3" NY="6" NZ="4"
                      LX="0,20" LY="0,100" LZ="0,10"/>
    </Geometry>


    <Materials>
      <Solid name="rock" cellTags="1">
        <Constitutive>
          <Elastic youngModulus="10e6" poissonRatio="0.25"/>
        </Constitutive>
      </Solid>
    </Materials>


    <BoundaryConditions>
      <BC name="fix_bottom" type="Dirichlet" field="surface"
          variable="displacements"
          entityListType = "tags" entityList = "1" components = "z">
        <BCevent time="0" value="0"/>
      </BC>

      <BC name="y_fix" type="Dirichlet" field="surface"
          variable="displacements"
           entityListType = "tags" entityList = "3,4" components = "y">
        <BCevent time="0" value="0"/>
      </BC>

      <BC name="x_fix" type="Dirichlet" field="surface"
          variable="displacements"
           entityListType = "tags" entityList = "5" components = "x">
        <BCevent time="0" value="0"/>
      </BC>
    </BoundaryConditions>


    <Solver>
      <Poromechanics/>
    </Solver>
</Problem>
