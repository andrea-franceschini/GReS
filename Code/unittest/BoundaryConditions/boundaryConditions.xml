<?xml version="1.0" encoding="UTF-8"?>

<!-->

'entityListType'
specifies how the ID of the constrained entities is given.

'bcListFile'
a path to a list of entities ID of type specified by 'field'
(see the BoundaryConditions tutorial)

'tags'
the tags to which the constrained entities belong

'bcList'
a simple list of entities to be constrained in the specified components

NOTE
for the case of multi-component fields where 'bcList' or 'tags'
are used, the user must also specify the 'component' attribute
component = "x" or component = "x,y,z" or component = "y,z"


<BCevent>
Each BC event needs a 'time' and a 'value' attribute

'time' can be:
a single scalar
a function handle of a scalar multiplier changing with time (t)

'value' can be:
a single scalar (constant in space for each dof),
a path to a file with a list of values for each dof
a function handle depending on space (x,y,z)

<-->


<BoundaryConditions>
  <BC
      name = "bc1"
      type = "Dirichlet"
      field = "surface"
      variable = "pressure"
      entityListType = "bcList"
      entityList = "1,13,168"
      >

    <BCevent
             time = "2*t"
             value = "10-z"
             />
  </BC>

  <BC
      name = "bc2"
      type = "Neumann"
      field = "surface"
      entityListType = "tags"
      entityList = "2"
      variable = "displacements"
      components = "x,z"
      >

    <BCevent
             time = "1"
             value = "-10"
             />

    <BCevent
             time = "3"
             value = "-5"
             />
    <BCevent
             time = "6"
             value = "z"
             />
  </BC>

  <BC
      name = "bc3"
      type = "Dirichlet"
      field = "node"
      variable = "displacements"
      entityListType = "bcListFile"
      entityList = "entityList"
      >

    <BCevent
             time = "1"
             value = "5"
             />
  </BC>


  <BC
      name = "bc4"
      type = "Dirichlet"
      field = "surface"
      variable = "displacements"
      entityListType = "tags"
      entityList = "4"
      components = "x"
      >

    <BCevent
             time = "0"
             value = "bcvals_list.dat"
             />
  </BC>

  <BC
      name = "bc5"
      type = "Dirichlet"
      field = "surface"
      variable = "displacements"
      entityListType = "tags"
      entityList = "1"
      components = "x,y,z"
      >

    <BCevent
             time = "0"
             value = "0"
             />


    <BCevent
             time = "5.0"
             value = "4"
             />

    <BCevent
             time = "3.0"
             value = "4"
             />

  </BC>



  <BC
      name = "bc6"
      type = "source"
      field = "cell"
      variable = "pressure"
      entityListType = "box"
      entityList = "0.2 0.8 0.2 0.8 3.0 6.0"
      >

    <BCevent
             time = "0"
             value = "0"
             />


    <BCevent
             time = "1.0"
             value = "1"
             />

  </BC>

</BoundaryConditions>