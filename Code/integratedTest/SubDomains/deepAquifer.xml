<?xml version="1.0" encoding="UTF-8"?>
<!-- This XML input file is a shortcut to preprocess the model for each domain
in a nonConforming simulation.
-->
<Problem>

  <Domain>
    <Geometry meshFile = "Input/ReservoirTest_Hexa.msh" />
    <Gauss nGP = "2" />
    <Materials fileName = "Input/materials.xml"/>
    <BoundaryConditions fileName = "Input/boundaryConditions.xml" />

    <Solver>
      <BiotFullyCoupled>
        <Poromechanics targetRegions = "1,2,3" />
        <SinglePhaseFlowFVTPFA targetRegions = "2,3" />
      </BiotFullyCoupled>
    </Solver>
  </Domain>

</Problem>
