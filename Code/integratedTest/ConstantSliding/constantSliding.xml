<?xml version="1.0" encoding="UTF-8"?>

<Problem>

  <SimulationParameters
          Start="0.0"
          End ="1e0"
          DtInit= "1e0"
          DtMax ="1e0"
          DtMin ="1.0"
          relativeTolerance = "1e-12"
          absoluteTolerance = "1e-11"
          />


  <!--Top domain-->
  <Domain>
    <Geometry
              meshFile = "Input/topBlock.vtk"
              />
    <Gauss nGP = "3" />
    <Materials fileName = "Input/materials.xml" />
    <BoundaryConditions fileName = "Input/constantSlidingTopBCs.xml" />
    <Solver>
      <Poromechanics />
    </Solver>
  </Domain>

  <!--Bottom domain-->
  <Domain>
    <Geometry meshFile = "Input/bottomBlock.vtk" />
    <Gauss nGP = "3" />
    <Materials fileName = "Input/materials.xml" />
    <BoundaryConditions fileName = "Input/constantSlidingBottomBCs.xml" />
    <Solver>
      <Poromechanics />
    </Solver>
  </Domain>

  <Interface>
    <SolidMechanicsContact
                           masterDomain = "2"
                           masterSurface = "3"
                           slaveDomain = "1"
                           slaveSurface = "1" >

      <Quadrature
                  type = "SegmentBasedQuadrature"
                  nGP = "6"
                  />


      <Coulomb 
               cohesion = "0" 
               frictionAngle = "5.71" />

    </SolidMechanicsContact>


  </Interface>

</Problem>

