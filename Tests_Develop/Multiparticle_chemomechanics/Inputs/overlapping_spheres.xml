<?xml version="1.0" encoding="UTF-8"?>

<Problem>

    <simParam fileName = "Inputs/simparam.xml" />

    <!-- Both spheres in contact defined by a common domain in the mesh -->
    <Domain>
        <Geometry
            fileName = "Inputs/TwoSpheres/left_overlapped_sphere.vtk"
        />
        <Gauss nGP = "1" />
        <Materials fileName = "Inputs/TwoSpheres/materials.xml" />
        <BoundaryConditions fileName = "Inputs/TwoSpheres/boundaries_leftSphere.xml" />
        <Output
            fileName = "Inputs/TwoSpheres/output_left.xml"
        />

        <Solver>
            <BiotFullySaturated>
                <Poromechanics />
                <SinglePhaseFlowFEM />
            </BiotFullySaturated>
        </Solver>
    </Domain>

    <Domain>
        <Geometry
            fileName = "Inputs/TwoSpheres/right_overlapped_sphere.vtk"
        />
        <Gauss nGP = "1" />
        <Materials fileName = "Inputs/TwoSpheres/materials.xml" />
        <BoundaryConditions fileName = "Inputs/TwoSpheres/boundaries_rightSphere.xml" />
        <Output
            fileName = "Inputs/TwoSpheres/output_right.xml"
        />

        <Solver>
            <BiotFullySaturated>
                <Poromechanics />
                <SinglePhaseFlowFEM />
            </BiotFullySaturated>
        </Solver>
    </Domain>

    <Interface>
        <MeshTying
            variable = "displacements" >
            <Master
                domainId = "1"
                surfaceTag = "3"
            />
            <Slave
                domainId = "2"
                surfaceTag = "3"
            />
            <Quadrature
                type = "SegmentBasedQuadrature"
                nGP = "4"
                nInt = "5"
                multiplierType = "dual"
            />

            <Output
                outputFile = "Outputs/Interface"
                printTimes = "0.1 0.2832 0.3 0.5 0.7 0.9 0.99"
            />
        </MeshTying>
    </Interface>
</Problem>
