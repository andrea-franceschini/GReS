<?xml version="1.0" encoding="UTF-8"?>

<Problem>

    <simParam fileName = "Inputs/simparam.xml" />

    <!-- Both spheres in contact defined by a common domain in the mesh -->
    <Domain>
        <Geometry
            fileName = "Inputs/PBP/pbp_leftSphere.vtk"
        />
        <Gauss nGP = "1" />
        <Materials fileName = "Inputs/PBP/materials_Zhang2007.xml" />
        <BoundaryConditions fileName = "Inputs/PBP/boundaries_leftSphere.xml" />
        <Output
            fileName = "Inputs/PBP/output_left.xml"
        />

        <Solver>
            <BiotFullySaturated>
                <Poromechanics />
                <SinglePhaseFlowFEM />
            </BiotFullySaturated>
        </Solver>
    </Domain>

    <Domain>
        <Geometry
            fileName = "Inputs/PBP/pbp_rightSphere.vtk"
        />
        <Gauss nGP = "1" />
        <Materials fileName = "Inputs/PBP/materials_Zhang2007.xml" />
        <BoundaryConditions fileName = "Inputs/PBP/boundaries_rightSphere.xml" />
        <Output
            fileName = "Inputs/PBP/output_right.xml"
        />

        <Solver>
            <BiotFullySaturated>
                <Poromechanics />
                <SinglePhaseFlowFEM />
            </BiotFullySaturated>
        </Solver>
    </Domain>

    <Domain>
        <Geometry
            fileName = "Inputs/PBP/pbp_binder.vtk"
        />
        <Gauss nGP = "1" />
        <Materials fileName = "Inputs/PBP/materials_binder_Zhang2007.xml" />
        <BoundaryConditions fileName = "Inputs/PBP/boundaries_binder.xml" />
        <Output
            fileName = "Inputs/PBP/output_binder.xml"
        />

        <Solver>
            <Poromechanics />
        </Solver>
    </Domain>

    <Interface>
        <MeshTying
            variable = "displacements" >
            <Master
                domainId = "1"
                surfaceTag = "2"
            />
            <Slave
                domainId = "3"
                surfaceTag = "-2"
            />
            <Quadrature
                type = "SegmentBasedQuadrature"
                nGP = "4"
                nInt = "5"
                multiplierType = "dual"
            />

            <Output
                outputFile = "Outputs/Interface_left"
                printTimes = "0.1 0.2 0.2832 0.3 0.5 0.7 0.9 0.99"
            />
        </MeshTying>
    </Interface>
</Problem>
