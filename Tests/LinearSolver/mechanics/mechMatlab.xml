<?xml version="1.0" encoding="UTF-8"?>
<!-- This XML input file is a shortcut to preprocess the model for each domain
in a nonConforming simulation.
-->

<Problem>

   <SimulationParameters
      Start="0."
      End ="2.0"
      DtInit="0.25"
      DtMin ="1e-5"
      DtMax ="0.5"
      incrementFactor = "1.25"
      choppingFactor = "2" 
      RelativeTolerance = "1.e-6"
      AbsoluteTolerance = "1.e-8"
      >
      <LinearSolver
         useMatlab="1">
      </LinearSolver>
  </SimulationParameters>


  <Materials >

    <Solid cellTags = "1" name = "mat">

    <Constitutive>

      <Elastic
               youngModulus = "5000.0"
               poissonRatio = "0.3"
               />
    </Constitutive>

  </Solid>
  </Materials>



  <BoundaryConditions>
    <BC
        name = "pressureBC"
        type = "Dirichlet"
        field = "cell"
        variable = "pressure"
        entityListType = "box"
        entityList = "50,55,50,55,5,6"
       >

      <BCevent
               time = "0"
               value = "100"
               />
    </BC>

  </BoundaryConditions>



  <Output
          printTimes   = "1,2,3,4"
          outputFile   = "model01/Output01/results"
          matFileName  = "model01/Output01/history"
          />


  <Solver>
    <SinglePhaseFlowFVTPFA />
  </Solver>
</Problem>
