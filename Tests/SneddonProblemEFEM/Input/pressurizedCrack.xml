<?xml version="1.0" encoding="UTF-8"?>
<struct>
  <SimulationParameters>
    <Start>0</Start>
    <End>1</End>
    <DtInit>1</DtInit>
    <DtMax>1</DtMax>
    <DtMin>1</DtMin>
    <AbsoluteTolerance>1e-08</AbsoluteTolerance>
    <RelativeTolerance>1e-09</RelativeTolerance>
    <MaxNLIteration>30</MaxNLIteration>
  </SimulationParameters>


  <Materials>
    <Solid
           name = "solid"
           cellTags = " 1 ">
      <Constitutive>
        <Elastic
                 youngModulus = "25000"
                 poissonRatio = "0.25"
                 />
      </Constitutive>

    </Solid>

  </Materials>

  <BoundaryConditions>
    <BC>
      <name>z_fix</name>
      <type>Dirichlet</type>
      <entityType>SurfBC</entityType>
      <variable>displacements</variable>
      <BCentities>
        <surfaceTags>1,2</surfaceTags>
        <components>z</components>
      </BCentities>
      <BCevent>
        <time>0</time>
        <value>0</value>
      </BCevent>
    </BC>
    <BC>
      <name>y_fix</name>
      <type>Dirichlet</type>
      <entityType>SurfBC</entityType>
      <variable>displacements</variable>
      <BCentities>
        <surfaceTags>3,4</surfaceTags>
        <components>y</components>
      </BCentities>
      <BCevent>
        <time>0</time>
        <value>0</value>
      </BCevent>
    </BC>
    <BC>
      <name>x_fix</name>
      <type>Dirichlet</type>
      <entityType>SurfBC</entityType>
      <variable>displacements</variable>
      <BCentities>
        <surfaceTags>5,6</surfaceTags>
        <components>x</components>
      </BCentities>
      <BCevent>
        <time>0</time>
        <value>0</value>
      </BCevent>
    </BC>
  </BoundaryConditions>

  <Solver>

    <EmbeddedFractureMechanics
                               penaltyNormal = "1e8"
                               penaltyTangential = "1e8">
      <Fracture
                origin = "0,0,0"
                normal = "0,0,1"
                lengthVec = "1,0,0"
                widthVec = "0,1,0"
                dimensions = "2,2"
                cohesion = "0"
                frictionAngle = "30"
                />

      <ActiveSet>
        <normalTraction>1e-6</normalTraction>
      </ActiveSet>
    </EmbeddedFractureMechanics>
  </Solver>

</struct>
