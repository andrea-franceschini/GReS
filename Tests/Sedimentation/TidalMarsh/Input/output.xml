<?xml version="1.0" encoding="UTF-8"?>

<Output
    outputFile = "Results/GReS"
    matFileName = "Results/GReS"
    saveHistory = "1"
    printTimes = "0.,250.,500.,750.,1000.,1250.,1500.,1750.,2000.,2250.,2500.,2750.,3000."
/>

<!-- 
outputFile: the name of the Paraview output file. If the file is not provided, then nothing is printed

saveHistory: save appropriate history output to mat file at specified printTimes. 
Default "0": do not save history, "1": save history

printTimes: list of time instant where the output solution is computed
Can be directly specified here as a comma separated list of numbers, or can be a path to a file containing the list.
-->