<?xml version="1.0" encoding="UTF-8"?>
<!-- This XML input file is a shortcut to preprocess the model for each domain
in a nonConforming simulation.
-->

<Problem>

  <SimulationParameters
                        Start="0."
                        End ="13.0"
                        DtInit="1"
                        DtMin ="1e-5"
                        DtMax ="1"
                        incrementFactor = "1.5"
                        choppingFactor = "2"
                        MaxNLIteration = "10"
                        RelativeTolerance = "1.e-10"
                        AbsoluteTolerance = "1.e-8"
                        resetConfiguration = "1"
                        />

  <Interface>
    <SolidMechanicsContact
                           stabilizationScale = "1.0"
                           masterDomain = "1" masterSurface = "6"
                           slaveDomain = "2" slaveSurface = "5">

      <Quadrature
                  type = "SegmentBasedQuadrature"
                  nGP = "4"
                  />

      <Coulomb
               cohesion = "0.0"
               frictionAngle = "30" />

      <ActiveSet
                 resetActiveSet = "0"
                 forceStickBoundary = "0" >

        <Tolerances
                    sliding = "1e-3"
                    normalGap = "1e-6"
                    normalTraction = "-1e-3"
                    tangentialViolation = "1e-5"
                    minLimitTraction = "1e-4"
                    areaChange = "1e-4"
                    maxActiveSetChange = "6"
                    />

      </ActiveSet>

    </SolidMechanicsContact>

  </Interface>


</Problem>
